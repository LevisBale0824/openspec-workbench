# OpenCode 服务配置
VITE_OPENCODE_BASE_URL=http://localhost:13284

# 应用配置
VITE_APP_NAME=OpenSpec Workbench
VITE_APP_VERSION=1.0.0

# 开发模式（开发环境设为 true，生产环境设为 false）
VITE_DEV_MODE=true

# Electron 配置（仅 Electron 模式生效）
VITE_ELECTRON_ENABLED=false

# 日志级别 (error | warn | info | debug)
VITE_LOG_LEVEL=info

# API 配置
VITE_API_TIMEOUT=30000

# 功能开关
VITE_ENABLE_FILE_TREE=true
VITE_ENABLE_SESSION_MANAGEMENT=true
VITE_ENABLE_FLOATING_WINDOWS=true

# 国际化
VITE_DEFAULT_LOCALE=zh-CN
VITE_AVAILABLE_LOCALES=zh-CN,en-US

# 调试选项（仅开发环境）
VITE_DEBUG_MODE=false
VITE_SHOW_DEV_TOOLS=false