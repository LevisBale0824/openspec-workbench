{
  "name": "openspec-workbench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "vue-tsc --noEmit",
    "electron:start": "node scripts/electron-start.mjs",
    "electron:build": "vite build && electron-builder",
    "bridge:build": "tsc -p cli-bridge/tsconfig.json",
    "bridge:start": "node cli-bridge/dist/server.js"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "vue": "^3.5.28",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@shikijs/markdown-it": "^4.2.0",
    "@shikijs/transformers": "^4.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "happy-dom": "^17.0.0",
    "markdown-it": "^14.2.0",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.4"
  }
}
